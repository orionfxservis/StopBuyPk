<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Qeemat Point</title>
    <link rel="stylesheet" href="../css/style.css"> <!-- Reusing main styles for variables -->
    <link rel="stylesheet" href="../css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <!-- Click Sound -->
    <audio id="clickSound" src="../click.mp3"></audio>

    <div class="admin-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo" style="padding: 10px 0; display: flex; flex-direction: column; align-items: center; gap: 5px;">
                <img src="../images/logo/stopbuy-logo.png" alt="StopBuy Admin Pannel" style="max-width: 20%; height: auto; border-radius: 8px;">
                <span style="font-size: 14px; color: #cbd5e1; font-weight: bold;">StopBuy Admin Panel</span>
            </div>
            <ul class="menu">
                <li onclick="showSection('dashboard')"><i class="fa-solid fa-chart-line"></i> Dashboard</li>
                <li onclick="showSection('categories')"><i class="fa-solid fa-layer-group"></i> Manage Categories</li>
                <li onclick="showSection('products')"><i class="fa-solid fa-box"></i> Manage Products</li>
                <li onclick="showSection('deals')"><i class="fa-solid fa-fire"></i> Manage Deals</li>
                <li onclick="showSection('users')"><i class="fa-solid fa-users"></i> Manage Users</li>
                <li onclick="showSection('ads')"><i class="fa-solid fa-bullhorn"></i> Place Ads</li>
                <li onclick="showSection('banners')"><i class="fa-solid fa-image"></i> Manage Banners</li>
                <li onclick="showSection('blogs')"><i class="fa-solid fa-blog"></i> Manage Blogs</li>
                <li onclick="showSection('broadcasts')"><i class="fa-solid fa-bullhorn"></i> Manage Broadcasts</li>
                <li onclick="showSection('travel')"><i class="fa-solid fa-plane"></i> Manage Travel <span id="travelPendingBadge" style="display:none; background:#eab308; color:#000; border-radius:50%; padding:2px 6px; font-size:10px; margin-left:5px; font-weight:bold;">0</span></li>
                <li onclick="showSection('daily-prices')"><i class="fa-solid fa-chart-bar"></i> Manage Daily Prices</li>
                <li onclick="logout()"><i class="fa-solid fa-sign-out-alt"></i> Logout</li>
            </ul>
        </aside>

        <!-- Main Content -->
        <main class="content">
            <!-- Dashboard Overview -->
            <section id="dashboard" class="admin-section active">
                <h1>Dashboard Overview</h1>
                
                <!-- Four Stat Boxes -->
                <div class="stats-grid section-spacing" style="margin-bottom: 2rem;">
                  <div class="stat-card blue">
                    <div class="stat-content">
                      <h3 class="stat-label">Total Registered Companies</h3>
                      <p class="stat-value"><span id="totalCompanies">5</span> <span class="stat-link" style="font-size:0.7rem; color:var(--primary-color); cursor:pointer; margin-left: 10px;">View Details</span></p>
                    </div>
                  </div>
                  <div class="stat-card teal">
                    <div class="stat-content">
                      <h3 class="stat-label">Total Products</h3>
                      <p class="stat-value"><span id="totalProducts">0</span> <span class="stat-link" style="font-size:0.7rem; color:var(--primary-color); cursor:pointer; margin-left: 10px;">View Details</span></p>
                    </div>
                  </div>
                  <div class="stat-card yellow">
                    <div class="stat-content">
                      <h3 class="stat-label">Total Users</h3>
                      <p class="stat-value"><span id="totalUsers">12</span> <span class="stat-link" style="font-size:0.7rem; color:var(--primary-color); cursor:pointer; margin-left: 10px;">View Records</span></p>
                    </div>
                  </div>
                  <div class="stat-card red">
                    <div class="stat-content">
                      <h3 class="stat-label">Total Categories</h3>
                      <p class="stat-value"><span id="totalCategories">0</span> <span class="stat-link" style="font-size:0.7rem; color:var(--primary-color); cursor:pointer; margin-left: 10px;">Review Lists</span></p>
                    </div>
                  </div>
                </div>

                <!-- Broadcast Scroll Bar -->
                <div id="broadcastContainer" class="broadcast-container section-spacing">
                  <div class="broadcast-icon" style="color: #f59e0b;"><i class="fa-solid fa-bullhorn"></i></div>
                  <div class="broadcast-wrapper">
                    <div class="broadcast-content" id="broadcastText">
                      Welcome to Qeemat Point Admin! &nbsp;|&nbsp; System Running Smoothly &nbsp;|&nbsp; New Products Registered!
                    </div>
                  </div>
                </div>

                <!-- Quick Actions -->
                <div class="quick-actions-grid section-spacing">
                  <div class="quick-action" data-target="purchase.html">New Purchase <i class="fa-solid fa-cart-shopping"></i></div>
                  <div class="quick-action" data-target="sales.html">New Sale <i class="fa-solid fa-cash-register"></i></div>
                  <div class="quick-action" data-target="expenses.html">Add Expense <i class="fa-solid fa-money-bill-wave"></i></div>
                  <div class="quick-action" data-target="inventory.html">Inventory <i class="fa-solid fa-boxes-stacked"></i></div>
                  <div class="quick-action" data-target="reports.html">Report <i class="fa-solid fa-file-invoice"></i></div>
                </div>


                <!-- Charts & Low Stock -->
                <div class="chart-row section-spacing">
                  <div class="chart-col">
                    <div class="form-container chart-container-fixed">
                      <h3 style="margin-bottom: 5px;">Total Sale</h3>
                      <div style="position: relative; height:200px; width:100%;"><canvas id="pharaSalesChart"></canvas></div>
                    </div>
                    <div class="form-container">
                      <h3 style="color:#f59e0b;"><i class="fa-solid fa-triangle-exclamation"></i> Low Stock Alerts</h3>
                      <table class="admin-table">
                        <tbody id="lowStockTableBody">
                          <tr><td style="color:#aaa; text-align:center;">Working On It</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>

                  <div class="chart-col">
                    <div class="form-container chart-container-fixed">
                      <h3 style="margin-bottom: 5px;">Credit Tracking</h3>
                      <div style="position: relative; height:200px; width:100%;"><canvas id="pharaCreditChart"></canvas></div>
                    </div>
                    <div class="form-container">
                      <h3 style="color:#38bdf8;"><i class="fa-solid fa-clock"></i> Recent Activity</h3>
                      <div id="recentActivity">
                        <ul style="list-style:none; padding:0; margin:0; font-size:0.9rem;">
                          <li style="padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.1);">🧾 Sale recorded - Rs 5,000</li>
                          <li style="padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.1);">📦 Purchase added - 20 items</li>
                          <li style="padding:6px 0;">💸 Expense added - Rs 1,200</li>
                        </ul>
                      </div>
                    </div>
                  </div>

                  <div class="chart-col">
                    <div class="form-container chart-container-fixed">
                      <h3 style="margin-bottom: 5px;">Inventory</h3>
                      <div style="position: relative; height:200px; width:100%;"><canvas id="pharaInventoryChart"></canvas></div>
                    </div>
                    <div class="form-container">
                      <h3 style="color:#22c55e;"><i class="fa-solid fa-arrow-trend-up"></i> Top Selling Products</h3>
                      <div id="topSellingList"><p style="color:#aaa;">No sales data available</p></div>
                    </div>
                  </div>
                </div>
            </section>

            <!-- Category Management -->
            <section id="categories" class="admin-section">
                <h1>Manage Categories</h1>

                <div class="form-container">
                    <h3>Add New Category</h3>
                    <form id="categoryForm">
                        <div class="form-row">
                            <div class="input-group">
                                <label>Category Name</label>
                                <input type="text" id="catName" placeholder="e.g., Electronics" required style="max-width: 300px;">
                            </div>
                        </div>
                        <div id="fieldsContainer" style="margin-top: 20px;">
                            <!-- Dynamic fields will be added here -->
                        </div>
                        <div class="form-actions" style="margin-top: 15px;">
                            <button type="button" class="btn btn-secondary" onclick="addField()">+ Add Field</button>
                            <button type="submit" class="btn btn-primary" id="btnSaveCategory">Add Category</button>
                            <button type="button" class="btn btn-secondary" id="btnCancelCategory" style="display:none;" onclick="cancelCategoryEdit()">Cancel Edit</button>
                        </div>
                    </form>
                </div>

                <div class="list-container">
                    <h3>Existing Categories</h3>
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Fields</th>
                                <th>Visibility</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="categoryList">
                            <!-- Categories will be injected here -->
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Product Management (Placeholder for Company View mostly) -->
            <section id="products" class="admin-section">
                <h1>Manage Products</h1>

                <div class="form-container">
                    <h3>Add New Product</h3>
                    <form id="adminProductForm">
                        <div class="form-row">
                            <div class="input-group">
                                <label>Choose Category</label>
                                <select id="prodCategory" required>
                                    <option value="">Select Category</option>
                                    <!-- Populated via JS -->
                                </select>
                            </div>
                            <div class="input-group">
                                <label>Select Sub Category</label>
                                <select id="prodSubCategory" required>
                                    <option value="">Select Sub Category</option>
                                    <!-- Populated via JS -->
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="input-group">
                                <label>Image</label>
                                <div style="display: flex; gap: 10px;">
                                    <input type="url" id="prodImage" placeholder="https://..." style="flex: 1;">
                                    <input type="file" id="prodImageUpload" accept="image/*" style="display: none;">
                                    <button type="button" class="btn btn-secondary"
                                        onclick="document.getElementById('prodImageUpload').click()"
                                        style="padding: 10px 15px;"><i class="fa-solid fa-upload"></i></button>
                                </div>
                                <span id="prodUploadStatus"
                                    style="font-size: 0.8rem; color: var(--accent-color); margin-top: 5px; display: none;">Uploading...</span>
                            </div>
                        </div>

                        <!-- Dynamic Fields Injected Here -->
                        <div id="dynamicProductFields"></div>

                        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Add
                            Product</button>
                    </form>
                </div>

                <div class="list-container">
                    <h3>Existing Products</h3>
                    <div class="grid-table-header">
                        <div>Image</div>
                        <div>Name</div>
                        <div>Category</div>
                        <div>Price</div>
                        <div>Actions</div>
                    </div>
                    <div id="adminProductList">
                        <!-- Products injected here -->
                    </div>
                </div>
            </section>

            <!-- Place Ads Section -->
            <section id="ads" class="admin-section">
                <h1>Place Ads</h1>
                <div class="form-container">
                    <h3>Create New Ad</h3>
                    <p>Ad placement functionality coming soon...</p>
                </div>
            </section>

            <!-- Manage Deals of the Day -->
            <section id="deals" class="admin-section">
                <h1>Manage Deals of the Day</h1>
                <div class="form-container">
                    <h3 id="dealFormTitle">Add New Deal</h3>
                    <form id="dealForm">
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Deal Title / Name</label>
                                <input type="text" id="dealName" placeholder="e.g., Nike Running Shoes" required style="width: 100%;">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group">
                                <label>Image URL or Upload</label>
                                <div style="display: flex; gap: 10px;">
                                    <input type="url" id="dealImage" placeholder="https://..." required
                                        style="flex: 1;">
                                    <input type="file" id="dealImageUpload" accept="image/*" style="display: none;">
                                    <button type="button" class="btn btn-secondary"
                                        onclick="document.getElementById('dealImageUpload').click()"
                                        style="padding: 10px 15px;"><i class="fa-solid fa-upload"></i></button>
                                </div>
                                <span id="uploadStatus"
                                    style="font-size: 0.8rem; color: var(--accent-color); margin-top: 5px; display: none;">Uploading...</span>
                            </div>
                            <div class="input-group">
                                <label>Short Description</label>
                                <input type="text" id="dealDesc" placeholder="Max 2 lines description" required>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group">
                                <label>Price</label>
                                <input type="text" id="dealPrice" placeholder="e.g., Rs 4,500" required>
                            </div>
                            <div class="input-group">
                                <label>Location</label>
                                <input type="text" id="dealLocation" placeholder="e.g., Lahore" required>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group">
                                <label>WhatsApp Number</label>
                                <input type="text" id="dealWhatsapp" placeholder="e.g., +923001234567" required>
                            </div>
                            <div class="input-group">
                                <label>Video Link (TikTok/FB)</label>
                                <input type="url" id="dealVideo" placeholder="https://tiktok.com/...">
                            </div>
                        </div>
                        <div class="form-actions" style="margin-top: 15px;">
                            <button type="submit" class="btn btn-primary" id="btnSaveDeal">Add Deal</button>
                            <button type="button" class="btn btn-secondary" id="btnCancelDeal" style="display:none;"
                                onclick="cancelDealEdit()">Cancel Edit</button>
                        </div>
                    </form>
                </div>

                <div class="list-container">
                    <h3>Current Deals</h3>
                    <div class="grid-table-header">
                        <div>Image</div>
                        <div>Deal Info</div>
                        <div>Price/Loc</div>
                        <div>Actions</div>
                    </div>
                    <div id="dealList">
                        <!-- Deals injected here via JS -->
                    </div>
                </div>
            </section>

            <!-- User Management Section -->
            <section id="users" class="admin-section">
                <h1>Manage Users</h1>

                <div class="form-container">
                    <h3 id="userFormTitle">Add New User</h3>
                    <form id="userForm">
                        <div class="form-row">
                            <div class="input-group">
                                <label>Username</label>
                                <input type="text" id="userName" placeholder="e.g., Ali Khan" required>
                            </div>
                            <div class="input-group">
                                <label>Password</label>
                                <input type="text" id="userPassword" placeholder="User Password" required>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group">
                                <label>User Role / Type</label>
                                <select id="userRole" required>
                                    <option value="user">Normal User</option>
                                    <option value="company">Company</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                            <div class="input-group">
                                <label>Account Status</label>
                                <select id="userStatus" required>
                                    <option value="active">Active</option>
                                    <option value="hold">On Hold</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-actions" style="margin-top: 15px;">
                            <button type="submit" class="btn btn-primary" id="btnSaveUser">Save User</button>
                            <button type="button" class="btn btn-secondary" id="btnCancelUser" style="display:none;"
                                onclick="cancelUserEdit()">Cancel Edit</button>
                        </div>
                    </form>
                </div>

                <div class="list-container">
                    <h3>Registered Users</h3>
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Password</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="userList">
                            <!-- Users injected here via JS -->
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Banner Management Section -->
            <section id="banners" class="admin-section">
                <h1>Manage Banners</h1>
                <div class="form-container">
                    <h3>Add New Banner</h3>
                    <form id="bannerForm">
                        <div class="input-group">
                            <label>Banner Image URL</label>
                            <input type="url" id="bannerImage" placeholder="https://example.com/banner.jpg" required>
                        </div>
                        <div class="input-group">
                            <label>Banner Type</label>
                            <select id="bannerType" required>
                                <option value="horizontal">Horizontal Banner</option>
                                <option value="vertical">Vertical Scrolling Banner</option>
                            </select>
                        </div>
                        <div class="input-group">
                            <label>Weblink (Optional)</label>
                            <input type="url" id="bannerLink" placeholder="https://example.com/promo">
                        </div>
                        <div class="input-group">
                            <label>Preview</label>
                            <div id="bannerPreview" class="banner-preview">
                                <p>Image preview will appear here</p>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary">Add Banner</button>
                    </form>
                </div>

                <div class="list-container">
                    <h3>Existing Banners</h3>
                    <div id="bannerList" class="banner-grid">
                        <!-- Banners injected here -->
                    </div>
                </div>
            </section>

            <!-- Blog Management Section -->
            <section id="blogs" class="admin-section">
                <h1>Manage Blogs</h1>
                <div class="form-container">
                    <h3 id="blogFormTitle">Add New Blog Post</h3>
                    <form id="blogForm">
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Title (English) <span style="color:var(--accent-color);">*</span></label>
                                <input type="text" id="blogTitleEn" placeholder="e.g., How to save money on groceries" required>
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Slug (Auto-generated) <span style="color:var(--accent-color);">*</span></label>
                                <input type="text" id="blogSlug" placeholder="how-to-save-money-on-groceries" readonly required style="background: rgba(0,0,0,0.2); color:#94a3b8; cursor: not-allowed;">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Title (Urdu) <span style="color:var(--accent-color);">*</span></label>
                                <input type="text" id="blogTitleUr" placeholder="e.g., گروسری پر پیسے کیسے بچائیں" required dir="rtl">
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Author Name <span style="color:var(--accent-color);">*</span></label>
                                <input type="text" id="blogAuthor" placeholder="e.g., Ali Khan" required>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Category (Dropdown) <span style="color:var(--accent-color);">*</span></label>
                                <select id="blogCategoryDropdown" required>
                                    <option value="">Select Category</option>
                                    <option value="Grocery">Grocery</option>
                                    <option value="Electronics">Electronics</option>
                                    <option value="Fashion">Fashion</option>
                                    <option value="Inflation Insight">Inflation Insight</option>
                                    <option value="News">News</option>
                                    <option value="Tips">Tips</option>
                                </select>
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Category (Urdu) <span style="color:var(--accent-color);">*</span></label>
                                <input type="text" id="blogCategoryUr" placeholder="e.g., مہنگائی کا رجحان" required dir="rtl">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Blog Image URL <span style="color:var(--accent-color);">*</span></label>
                                <input type="url" id="blogImage" placeholder="https://example.com/blog-image.jpg" required>
                                <small style="color:#aaa;">Recommended aspect ratio: 16:9</small>
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Status <span style="color:var(--accent-color);">*</span></label>
                                <select id="blogStatus" required>
                                    <option value="Publish">Publish</option>
                                    <option value="Draft">Draft</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>SEO Title</label>
                                <input type="text" id="blogSeoTitle" placeholder="Optimized title for search engines...">
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Meta Description</label>
                                <input type="text" id="blogMetaDesc" placeholder="Brief meta description for SEO...">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Short Description (English) <span style="color:var(--accent-color);">*</span></label>
                                <input type="text" id="blogDescEn" placeholder="Brief summary for the card..." required>
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Short Description (Urdu) <span style="color:var(--accent-color);">*</span></label>
                                <input type="text" id="blogDescUr" placeholder="مختصر تفصیل..." required dir="rtl">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Content (English) <span style="color:var(--accent-color);">*</span></label>
                                <textarea id="blogContentEn" rows="6" placeholder="Write your blog content here..." required style="width: 100%; border: 1px solid var(--border-color); background: var(--bg-dark); color: var(--text-color); padding: 10px; border-radius: 5px;"></textarea>
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Content (Urdu) <span style="color:var(--accent-color);">*</span></label>
                                <textarea id="blogContentUr" rows="6" placeholder="یہاں اپنا بلاگ لکھیں..." required dir="rtl" style="width: 100%; border: 1px solid var(--border-color); background: var(--bg-dark); color: var(--text-color); padding: 10px; border-radius: 5px;"></textarea>
                            </div>
                        </div>
                        <div class="form-actions" style="margin-top: 15px;">
                            <button type="submit" class="btn btn-primary" id="btnSaveBlog">Publish</button>
                            <button type="button" class="btn btn-secondary" id="btnCancelBlog" style="display:none;" onclick="cancelBlogEdit()">Cancel Edit</button>
                        </div>
                    </form>
                </div>

                <div class="list-container">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h3 style="margin: 0;">Existing Blogs</h3>
                        <div class="search-filter-bar" style="display: flex; gap: 10px;">
                            <input type="text" id="blogSearchInput" placeholder="Search blog..." style="padding: 8px 12px; border-radius: 8px; border: 1px solid var(--border-color); background: rgba(15, 23, 42, 0.8); color: white;">
                            <select id="blogCategoryFilter" style="padding: 8px 12px; border-radius: 8px; border: 1px solid var(--border-color); background: rgba(15, 23, 42, 0.8); color: white;">
                                <option value="All">All Categories</option>
                                <option value="Grocery">Grocery</option>
                                <option value="Electronics">Electronics</option>
                                <option value="Fashion">Fashion</option>
                                <option value="Inflation Insight">Inflation Insight</option>
                                <option value="News">News</option>
                                <option value="Tips">Tips</option>
                            </select>
                        </div>
                    </div>
                    <div class="grid-table-header" style="grid-template-columns: 40px 60px 2fr 1fr 1fr 80px 100px 100px;">
                        <div><input type="checkbox" id="selectAllBlogs"></div>
                        <div>Image</div>
                        <div>Title</div>
                        <div>Category</div>
                        <div>Status</div>
                        <div>Views</div>
                        <div>Date</div>
                        <div>Actions</div>
                    </div>
                    <div id="blogList">
                        <!-- Blogs injected here -->
                    </div>
                </div>
            </section>

            <!-- Broadcast Management Section -->
            <section id="broadcasts" class="admin-section">
                <h1>Manage Broadcasts</h1>
                <div class="form-container">
                    <h3 id="broadcastFormTitle">Create New Broadcast</h3>
                    <form id="broadcastForm">
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Message Content <span style="color:var(--accent-color);">*</span></label>
                                <textarea id="broadcastMessage" rows="4" placeholder="Enter your message here..." required style="width: 100%; border: 1px solid var(--border-color); background: var(--bg-dark); color: var(--text-color); padding: 10px; border-radius: 5px;"></textarea>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="input-group" style="flex: 1;">
                                <label>Target Audience <span style="color:var(--accent-color);">*</span></label>
                                <select id="broadcastAudience" required onchange="toggleSpecificUserField()">
                                    <option value="all">All Users (Dashboard Ticker)</option>
                                    <option value="specific">Specific User</option>
                                </select>
                            </div>
                            <div class="input-group" style="flex: 1;">
                                <label>Status <span style="color:var(--accent-color);">*</span></label>
                                <select id="broadcastStatus" required>
                                    <option value="active">Active</option>
                                    <option value="inactive">Inactive</option>
                                    <option value="delete">Delete (Remove)</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-row" id="specificUserGroup" style="display: none;">
                            <div class="input-group" style="flex: 1;">
                                <label>Select User <span style="color:var(--accent-color);">*</span></label>
                                <select id="broadcastSpecificUser">
                                    <option value="">-- Choose User --</option>
                                    <!-- Populated dynamically via JS -->
                                </select>
                            </div>
                        </div>
                        <div class="form-actions" style="margin-top: 15px;">
                            <button type="submit" class="btn btn-primary" id="btnSaveBroadcast">Save Broadcast</button>
                            <button type="button" class="btn btn-secondary" id="btnCancelBroadcast" style="display:none;" onclick="cancelBroadcastEdit()">Cancel Edit</button>
                        </div>
                    </form>
                </div>

                <div class="list-container">
                    <h3>Broadcast History</h3>
                    <div class="grid-table-header" style="grid-template-columns: 1fr 2fr 100px 100px 100px;">
                        <div>Target</div>
                        <div>Message</div>
                        <div>Date</div>
                        <div>Status</div>
                        <div>Actions</div>
                    </div>
                    <div id="broadcastList">
                        <!-- Broadcasts injected here via JS -->
                    </div>
                </div>
            </section>

            <!-- Travel Management -->
            <section id="travel" class="admin-section">
                <h1>Manage Travel Packages</h1>
                <div class="travel-form">
                    <h2 id="travelFormTitle" style="color:var(--primary-color); margin-bottom: 20px;">Add Travel Package</h2>
                    <form id="travelForm" style="display:flex; flex-direction:column; gap:10px;">
                        <!-- Company Info -->
                        <div style="display:flex; gap:10px;">
                            <input type="text" id="travelCompany" placeholder="Company Name *" required class="admin-input" style="flex:1;">
                            <input type="text" id="travelContact" placeholder="Contact Number *" required class="admin-input" style="flex:1;">
                        </div>
                        <div style="display:flex; gap:10px;">
                            <input type="text" id="travelWhatsapp" placeholder="WhatsApp Number" class="admin-input" style="flex:1;">
                            <input type="email" id="travelEmail" placeholder="Email" class="admin-input" style="flex:1;">
                        </div>
                        
                        <!-- Package Details -->
                        <div style="display:flex; gap:10px;">
                            <input type="text" id="travelTitle" placeholder="Package Title *" required class="admin-input" style="flex:1;">
                            <select id="travelCategory" required class="admin-input" style="flex:1;">
                                <option value="">Category *</option>
                                <option value="Hajj">Hajj</option>
                                <option value="Umrah">Umrah</option>
                                <option value="Pakistan Tour">Pakistan Tour</option>
                                <option value="International Tour">International Tour</option>
                            </select>
                        </div>
                        <div style="display:flex; gap:10px;">
                            <input type="text" id="travelDeparture" placeholder="Departure City *" required class="admin-input" style="flex:1;">
                            <input type="text" id="travelDestination" placeholder="Destination *" required class="admin-input" style="flex:1;">
                        </div>
                        
                        <!-- Pricing & Duration -->
                        <div style="display:flex; gap:10px;">
                            <input type="number" id="travelDuration" placeholder="Duration (Days) *" required class="admin-input" style="flex:1;">
                            <input type="number" id="travelPrice" placeholder="Price (PKR) *" required class="admin-input" style="flex:1;">
                            <select id="travelPriceType" class="admin-input" style="flex:1;">
                                <option value="Per Person">Per Person</option>
                                <option value="Per Family">Per Family</option>
                            </select>
                        </div>
                        
                        <!-- Travel Details -->
                        <div style="display:flex; gap:10px;">
                            <select id="travelTransport" class="admin-input" style="flex:1;">
                                <option value="None">Transport</option>
                                <option value="Air">Air</option>
                                <option value="Bus">Bus</option>
                                <option value="Private">Private</option>
                            </select>
                            <select id="travelHotel" class="admin-input" style="flex:1;">
                                <option value="None">Hotel Type</option>
                                <option value="3 Star">3 Star</option>
                                <option value="4 Star">4 Star</option>
                                <option value="5 Star">5 Star</option>
                            </select>
                            <select id="travelMeals" class="admin-input" style="flex:1;">
                                <option value="No">Meals Included: No</option>
                                <option value="Yes">Meals Included: Yes</option>
                            </select>
                        </div>
                        
                        <!-- Extra Features -->
                        <div style="display:flex; gap:10px;">
                            <select id="travelGuide" class="admin-input" style="flex:1;">
                                <option value="No">Guide Included: No</option>
                                <option value="Yes">Guide Included: Yes</option>
                            </select>
                            <input type="text" id="travelZiyarat" placeholder="Ziyarat / Tour Points" class="admin-input" style="flex:2;">
                        </div>
                        
                        <!-- Media -->
                        <div style="display:flex; gap:10px;">
                            <input type="url" id="travelImage" placeholder="Upload Image URL *" required class="admin-input" style="flex:1;">
                            <input type="url" id="travelBrochure" placeholder="Brochure URL (Optional)" class="admin-input" style="flex:1;">
                        </div>
                        
                        <!-- Description -->
                        <textarea id="travelDetails" rows="3" placeholder="Full Details *" required class="admin-input"></textarea>
                        
                        <!-- Status -->
                        <div style="display:flex; gap:10px;">
                            <select id="travelListingType" class="admin-input" style="flex:1;">
                                <option value="Basic">Listing: Basic (Free)</option>
                                <option value="Featured">Listing: Premium (Featured)</option>
                            </select>
                            <select id="travelVerified" class="admin-input" style="flex:1;">
                                <option value="No">Verified Company: No</option>
                                <option value="Yes">Verified Company: Yes</option>
                            </select>
                            <select id="travelStatus" class="admin-input" style="flex:1;">
                                <option value="Publish">Status: Publish</option>
                                <option value="Draft">Status: Draft</option>
                            </select>
                        </div>
                        
                        <div style="display:flex; gap:10px; margin-top: 5px;">
                            <button type="submit" id="btnSaveTravel" class="btn btn-primary" style="flex:1; padding:10px; font-weight:bold;">Submit Package</button>
                            <button type="button" id="btnCancelTravel" class="btn btn-secondary" style="display:none; flex:1; padding:10px; font-weight:bold;" onclick="cancelTravelEdit()">Cancel Edit</button>
                        </div>
                    </form>
                </div>

                <div class="list-container">
                    <h3>Existing Packages</h3>
                    <div class="grid-table-header" style="grid-template-columns: 80px 2fr 1fr 1fr 1fr 1fr 80px;">
                        <div>Image</div>
                        <div>Company & Title</div>
                        <div>Category</div>
                        <div>Duration</div>
                        <div>Price</div>
                        <div>Status/Level</div>
                        <div>Actions</div>
                    </div>
                    <div id="travelList">
                        <!-- Packages injected here -->
                    </div>
                </div>
            </section>

            <!-- Manage Daily Prices Section -->
            <section id="daily-prices" class="admin-section">
                <h1>Manage Daily Prices</h1>
                <div class="list-container">
                    <h3>Uploaded PDF Sources</h3>
                    <div class="overflow-x-auto">
                        <table class="admin-table w-full text-sm">
                            <thead>
                                <tr>
                                    <th class="text-left">Date</th>
                                    <th class="text-left">File Name</th>
                                    <th class="text-left">Status</th>
                                    <th class="text-left">Price Status</th>
                                    <th class="text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody id="dailyPriceTable">
                                <!-- JS will load data here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="../js/data-service.js"></script>
    <script src="../js/admin.js"></script>
	<script src="../js/blog-manager.js"></script>
</body>

</html>