<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Categories - StopBuy</title>

<style>

/* ===== THEME ===== */
:root {
  --primary: #16a34a;
  --primary-dark: #065f46;
  --bg: #f5f7f6;
  --card: #ffffff;
  --text: #1f2937;
  --border: #e5e7eb;
}

/* ===== BODY ===== */
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: var(--bg);
  color: var(--text);
}

/* ===== HEADER ===== */
.header {
  background: linear-gradient(90deg, #065f46, #16a34a);
  color: white;
  padding: 12px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header a {
  color: white;
  text-decoration: none;
  font-weight: 500;
}

/* 🔷 HEADER BASE */
.main-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(90deg, #065f46, #16a34a);
  padding: 10px 20px;
  color: white;
  gap: 15px;
  flex-wrap: wrap;
}

/* LEFT */
.header-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo {
  height: 34px;
}

.brand-name {
  font-size: 18px;
  font-weight: 600;
}

/* CENTER SEARCH */
.header-center {
  flex: 1;
  display: flex;
  justify-content: center;
}

.header-center input {
  width: 100%;
  max-width: 420px;
  padding: 8px 12px;
  border-radius: 8px;
  border: none;
  outline: none;
  font-size: 14px;
}

/* RIGHT ACTIONS */
.header-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.header-right button {
  background: rgba(255,255,255,0.1);
  border: none;
  color: white;
  padding: 6px 10px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  transition: 0.25s;
}

.header-right button:hover {
  background: rgba(255,255,255,0.25);
}

/* LOGIN BUTTON */
.login-btn {
  background: white !important;
  color: #065f46 !important;
  font-weight: 600;
}

/* LANGUAGE BUTTON */
.lang-toggle {
  font-weight: 500;
}

/* ===== HERO ===== */
.category-hero {
  background: linear-gradient(135deg, #ecfdf5, #f0fdf4);
  padding: 30px;
  border-radius: 16px;
  margin: 20px;
}

/* ===== CATEGORY STRIP ===== */
.category-strip {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding: 10px 20px;
}

.category-strip button {
  background: #fff;
  border: 1px solid var(--border);
  padding: 8px 16px;
  border-radius: 999px;
  cursor: pointer;
}

.category-strip button:hover {
  background: #ecfdf5;
  border-color: var(--primary);
}

/* ===== SECTIONS ===== */
.category-section {
  padding: 20px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.view-more {
  color: var(--primary);
  cursor: pointer;
  font-weight: 500;
}

/* ===== CARDS ===== */
.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.card {
  background: #fff;
  border-radius: 12px;
  border: 1px solid var(--border);
  padding: 12px;
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-4px);
}

.card img {
  width: 100%;
  height: 120px;
  object-fit: cover;
  border-radius: 8px;
}

.card h4 {
  margin: 8px 0 4px;
}

.card p {
  color: #16a34a;
  font-weight: bold;
}

/* ===== FOOTER ===== */
.footer {
  background: linear-gradient(90deg, #065f46, #022c22);
  color: white;
  padding: 20px;
  text-align: center;
  margin-top: 40px;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .card-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .card-grid {
    grid-template-columns: 1fr;
  }
}

/* 🔷 TOP BAR */
.top-bar {
  display: flex;
  align-items: center;           /* ✅ vertical center fix */
  justify-content: space-between;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 10px 15px;
  margin-bottom: 20px;
  gap: 10px;
}

/* CATEGORY ICONS */
.category-icons {
  display: flex;
  align-items: center;           /* ✅ vertical center */
  gap: 8px;
  overflow-x: auto;
  flex: 1;                       /* ✅ take left space */
}

/* BUTTON STYLE */
.category-icons button {
  display: flex;
  align-items: center;           /* ✅ icon + text center */
  gap: 6px;
  padding: 6px 14px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: #fff;
  font-size: 13px;
  cursor: pointer;
  white-space: nowrap;
  transition: 0.25s;
}

.category-icons button:hover {
  background: #ecfdf5;
  border-color: var(--primary);
  color: var(--primary);
}

/* RIGHT SIDE (SEARCH + FILTER) */
.right-controls {
  display: flex;
  align-items: center;           /* ✅ vertical center */
  gap: 8px;
  flex-shrink: 0;                /* ✅ stay on right */
}

/* SEARCH */
.right-controls input {
  height: 34px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  outline: none;
}

/* DROPDOWN */
.right-controls select {
  height: 34px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  cursor: pointer;
}

/* SEARCH + FILTER */
.search-filter {
  display: flex;
  gap: 8px;
  align-items: center;
}

.search-filter input {
  padding: 7px 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  outline: none;
  width: 180px;
}

.search-filter select {
  padding: 7px 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  cursor: pointer;
}

@media (max-width: 768px) {
  .top-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .search-filter {
    width: 100%;
    justify-content: space-between;
  }

  .search-filter input {
    width: 100%;
  }
}

  .category-icons {
    width: 100%;
  }

  .right-controls {
    width: 100%;
    justify-content: space-between;
  }

  .right-controls input {
    width: 100%;
  }
}

/* 🔷 TOP SECTION BOX */
.top-section {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 20px;
}

/* 🔹 CATEGORY ROW (LINE 1) */
.category-row {
  display: flex;
  align-items: center;              /* ✅ vertical center */
  justify-content: center;          /* ✅ center whole row */
  gap: 10px;
  padding: 10px 20px;               /* ✅ balanced left-right spacing */
  overflow-x: auto;
}

/* OPTIONAL: limit width for perfect balance */
.category-row {
  max-width: 1100px;
  margin: 0 auto;                   /* ✅ center container */
}

/* BUTTON STYLE */
.category-row button {
  display: flex;
  align-items: center;              /* ✅ icon + text aligned */
  gap: 6px;
  padding: 7px 14px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: #fff;
  font-size: 13px;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.25s ease;
}

.category-row button:hover {
  background: #ecfdf5;
  border-color: var(--primary);
  color: var(--primary);
  transform: translateY(-1px);
}

/* 🔹 SEARCH ROW (LINE 2 RIGHT SIDE) */
.search-row {
  display: flex;
  justify-content: flex-end;   /* ✅ push to RIGHT */
  align-items: center;
  gap: 8px;
}

/* SEARCH INPUT */
.search-row input {
  height: 34px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  outline: none;
  width: 200px;
}

/* DROPDOWN */
.search-row select {
  height: 34px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  cursor: pointer;
}
</style>
</head>

<body>

<!-- HEADER -->
<!-- 🔷 GLOBAL HEADER -->
<header class="main-header">

    <!-- LEFT: LOGO + NAME -->
    <div class="header-left">
        <img src="../images/logo.png" alt="StopBuy" class="logo">
        <span class="brand-name">StopBuy</span>
    </div>

    

</header>

<div class="header">
  <div><a href="../index.html">← Home</a></div>
  <div>Categories</div>
</div>

<!-- HERO -->
<div class="category-hero">
  <h1>Browse Categories</h1>
  <p>Compare prices across Pakistan</p>
</div>

<!-- 🔷 TOP SECTION -->
<div class="top-section">

    <!-- 🔹 LINE 1: CATEGORY ICONS -->
    <div class="category-row">
    <button>🍲 Food Stuffs</button>
    <button>🛒 Daily Groceries</button>
    <button>🔌 Electronics</button>
    <button>📱 Mobiles</button>
    <button>💻 Laptops</button>
    <button>🏠 Property</button>
    <button>👕 Fashion</button>
    <button>💄 Cosmetics</button>
    <button>🍼 Baby Care</button>
</div>

    <!-- 🔹 LINE 2: SEARCH + FILTER (RIGHT SIDE) -->
    <div class="search-row">
        <input type="text" placeholder="Search products...">
        <select>
            <option>Lowest Price</option>
            <option>Highest Price</option>
            <option>Closest Price</option>
        </select>
    </div>

</div>

<!-- CATEGORY: GROCERIES -->
<section id="groceries" class="category-section">
  <div class="section-header">
    <h2>Groceries</h2>
    <span class="view-more">View More →</span>
  </div>

  <div class="card-grid">
    <div class="card">
      <img src="../images/oil.jpg">
      <h4>Cooking Oil</h4>
      <p>Rs. 389</p>
    </div>

    <div class="card">
      <img src="../images/flour.jpg">
      <h4>Flour 10kg</h4>
      <p>Rs. 1250</p>
    </div>

    <div class="card">
      <img src="../images/sugar.jpg">
      <h4>Sugar 1kg</h4>
      <p>Rs. 145</p>
    </div>
  </div>
</section>

<!-- CATEGORY: MOBILES -->
<section id="mobiles" class="category-section">
  <div class="section-header">
    <h2>Mobiles</h2>
    <span class="view-more">View More →</span>
  </div>

  <div class="card-grid">
    <div class="card">
      <img src="../images/mobile1.jpg">
      <h4>iPhone 15</h4>
      <p>Rs. 257,999</p>
    </div>

    <div class="card">
      <img src="../images/mobile2.jpg">
      <h4>Samsung S23</h4>
      <p>Rs. 210,000</p>
    </div>

    <div class="card">
      <img src="../images/mobile3.jpg">
      <h4>Infinix Note</h4>
      <p>Rs. 45,000</p>
    </div>
  </div>
</section>

<!-- CATEGORY: ELECTRONICS -->
<section id="electronics" class="category-section">
  <div class="section-header">
    <h2>Electronics</h2>
    <span class="view-more">View More →</span>
  </div>

  <div class="card-grid">
    <div class="card">
      <img src="../images/tv.jpg">
      <h4>LED TV</h4>
      <p>Rs. 85,000</p>
    </div>

    <div class="card">
      <img src="../images/laptop.jpg">
      <h4>Laptop</h4>
      <p>Rs. 120,000</p>
    </div>

    <div class="card">
      <img src="../images/fridge.jpg">
      <h4>Refrigerator</h4>
      <p>Rs. 95,000</p>
    </div>
  </div>
</section>

<!-- CATEGORY: FASHION -->
<section id="fashion" class="category-section">
  <div class="section-header">
    <h2>Fashion</h2>
    <span class="view-more">View More →</span>
  </div>

  <div class="card-grid">
    <div class="card">
      <img src="../images/shirt.jpg">
      <h4>Men Shirt</h4>
      <p>Rs. 2,500</p>
    </div>

    <div class="card">
      <img src="../images/shoes.jpg">
      <h4>Shoes</h4>
      <p>Rs. 4,000</p>
    </div>

    <div class="card">
      <img src="../images/bag.jpg">
      <h4>Handbag</h4>
      <p>Rs. 3,200</p>
    </div>
  </div>
</section>

<!-- FOOTER -->
<div class="footer">
  © 2026 StopBuy - Smart Price Comparison
</div>

<!-- SCRIPT -->
<script>
function scrollToSection(id) {
  document.getElementById(id).scrollIntoView({
    behavior: 'smooth'
  });
}
</script>

</body>
</html>