				</a>
			</li>

            <li>
                <a href="#price-comparison"
                   class="flex items-center gap-2 px-4 py-2 hover:bg-emerald-50 hover:text-emerald-700">
                    <i class="fas fa-scale-balanced text-xs"></i> Price Comparison
                </a>
            </li>

            <li>
                <a href="#travel-section"
					class="flex items-center gap-2 px-4 py-2 hover:bg-emerald-50 hover:text-emerald-700">
					<i class="fas fa-plane text-xs"></i> Travel & Tours
				</a>
            </li>

            <li>
                <a href="pages/blog.html"
                   class="flex items-center gap-2 px-4 py-2 hover:bg-emerald-50 hover:text-emerald-700">
                    <i class="fas fa-blog text-xs"></i> Blogs
