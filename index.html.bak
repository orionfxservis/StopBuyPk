<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StopBuy - Pakistan's Smartest Price Comparison Platform</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', system_ui, sans-serif;
        }

        .section-header {
            font-size: 1.35rem;
            font-weight: 600;
            color: #0A3D2A;
        }

        .modern-shadow {
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.08), 0 4px 6px -4px rgb(0 0 0 / 0.08);
        }

        .page {
            display: none;
        }

        .page.active {
            display: block;
        }

        .deal-banner {
            scrollbar-width: thin;
            scrollbar-color: #059669 #f1f5f9;
        }

        .deal-banner::-webkit-scrollbar {
            width: 4px;
        }

        .deal-banner::-webkit-scrollbar-thumb {
            background-color: #059669;
            border-radius: 20px;
        }

        ::-webkit-scrollbar {
            height: 4px;
        }

        ::-webkit-scrollbar-thumb {
            background: #059669;
            border-radius: 10px;
        }

        /* Hide scrollbar for category navigation */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            /* IE and Edge */
            scrollbar-width: none;
            /* Firefox */
        }

        .filter-btn {
            border-color: #d1d5db;
        }

        .filter-btn.active {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
        }

        /* Animated Border for Visitor Counter */
        .animated-border-box {
            position: relative;
            border-radius: 9999px;
            overflow: hidden;
            padding: 1.5px;
            display: inline-flex;
        }

        .animated-border-box::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(transparent, transparent, transparent, #34d399);
            animation: border-rotate 3s linear infinite;
            z-index: 0;
        }

        @keyframes border-rotate {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .animated-border-content {
            position: relative;
            background-color: #052C22;
            border-radius: 9999px;
            z-index: 1;
        }

        /* Login Icon Hover Animation */
        .login-icon-container {
            border: 2px solid #34d399;
            transition: all 0.3s ease;
        }

        .login-icon-container:hover {
            transform: scale(1.05);
            background-color: rgba(52, 211, 153, 0.1);
        }

        .login-icon-container:hover i {
            animation: icon-rotate-y 2s linear infinite;
        }

        @keyframes icon-rotate-y {
            from {
                transform: rotateY(0deg);
            }
            to {
                transform: rotateY(360deg);
            }
        }
    </style>
</head>

<body class="bg-[#F8FAF9] text-[#1F2937]">

    <!-- Top Navigation Bar -->
    <nav class="bg-[#0A3D2A] text-white sticky top-0 z-[99999]">
        <div
            class="max-w-screen-2xl mx-auto px-4 py-2 sm:py-0 sm:h-[60px] flex flex-wrap sm:flex-nowrap items-center justify-between gap-y-3 gap-x-2 sm:gap-4">

            <!-- LEFT: Logo -->
            <div class="flex items-center gap-2 flex-shrink-0 order-1 sm:order-none">

                <div class="bg-white p-1 rounded-xl shadow-sm w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center">
                    <img src="./images/logo/stopbuy-logo.png" alt="StopBuy"
                        class="h-6 w-6 sm:h-7 sm:w-7 object-contain">
                </div>

                <div class="flex flex-col leading-tight">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-lg sm:text-xl tracking-tight">
                            <span class="text-[#8CC63F]">Stop</span><span class="text-[#5B9BD5]">Buy</span>
                        </span>

                        <div
                            class="hidden md:block border border-[#24533e] bg-emerald-900/20 text-[#58b284] px-2 py-[2px] rounded text-[10px] font-semibold tracking-wide">
                            Price Smart, Save More
                        </div>
                    </div>

                    <span class="hidden md:block text-[11px] text-gray-300 mt-0.5">
                        Smart Price Comparison for Pakistan
                    </span>
                </div>
            </div>

            <!-- CENTER: Search Bar -->
            <div class="order-3 sm:order-none w-full sm:w-auto sm:flex-1 max-w-xl flex items-center gap-3">
                <!-- Location -->
                <div class="hidden md:flex items-center gap-x-2 bg-white/10 hover:bg-white/15 px-4 py-1.5 rounded-3xl text-sm cursor-pointer"
                    onclick="showLocationModal()">
                    <i class="fas fa-map-marker-alt text-emerald-400"></i>
                    <span id="current-location">Karachi</span>
                    <i class="fas fa-chevron-down text-xs ml-1"></i>
                </div>

                <div class="relative flex-1">
                    <input type="text" placeholder="Search product, brand or store..."
                        onkeyup="if (event.key === 'Enter') performGlobalSearch()"
                        class="w-full h-[38px] bg-white text-[#1F2937] pl-9 pr-3 rounded-xl text-sm border border-white/20 focus:outline-none focus:ring-2 focus:ring-emerald-400 shadow-sm">
                    <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-emerald-600 text-sm"></i>
                </div>
            </div>

            <!-- RIGHT: Actions -->
            <div class="flex items-center gap-1 sm:gap-2 flex-shrink-0 order-2 sm:order-none">

                <!-- Compare -->
                <div onclick="showCompareModal()"
                    class="flex items-center gap-1.5 px-2 sm:px-3 h-[38px] hover:bg-white/10 rounded-xl cursor-pointer text-sm">
                    <i class="fas fa-balance-scale text-emerald-400"></i>
                    <span class="hidden md:inline">Compare</span>
                    <span
                        class="bg-emerald-600 text-white text-[10px] sm:text-xs font-bold px-1.5 py-0.5 rounded-full">3</span>
                </div>

                <!-- Alerts -->
                <div onclick="showAlertsModal()"
                    class="relative flex items-center gap-1.5 px-2 sm:px-3 h-[38px] hover:bg-white/10 rounded-xl cursor-pointer text-sm">
                    <i class="fas fa-bell text-emerald-400"></i>
                    <span class="hidden md:inline">Alerts</span>
                    <span
                        class="absolute top-0 sm:-top-1 right-0 sm:-right-1 bg-red-500 text-white text-[9px] sm:text-[10px] w-3.5 h-3.5 sm:w-4 sm:h-4 flex items-center justify-center rounded-full">12</span>
                </div>

                <!-- Language Toggle -->
                <div onclick="toggleLanguage()"
                    class="flex items-center justify-center px-3 sm:px-4 h-[34px] sm:h-[38px] bg-white/10 hover:bg-white/20 rounded-full text-xs sm:text-sm font-medium cursor-pointer transition-colors"
                    title="Switch Language">
                    <span id="lang-toggle-text">اردو</span>
                </div>

                <!-- Login Profile Icon -->
                <div onclick="showLoginModal()"
                    class="login-icon-container flex items-center justify-center w-[34px] h-[34px] sm:w-[42px] sm:h-[42px] rounded-full cursor-pointer bg-transparent">
                    <i class="fas fa-user-shield text-emerald-400 text-sm sm:text-lg"></i>
                </div>

            </div>

        </div>
        <!-- Category Bar -->
        <div class="bg-[#052C22] px-2 py-2 flex items-center relative z-50">

            <!-- Quick Links Dropdown -->
<div class="relative group flex-shrink-0 text-white mr-1 z-[100000]">
    
    <!-- Trigger -->
    <div class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer text-xs xl:text-[13px] font-medium flex items-center gap-1">
        <i class="fas fa-bars"></i>
        <span>Menu</span>
        <i class="fas fa-chevron-down text-[10px]"></i>
    </div>

    <!-- Dropdown -->
    <div class="absolute left-0 top-full mt-2 w-52 bg-white text-gray-800 rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">

        <ul class="py-2 text-sm font-normal">

            <li>
                <a href="index.html"
