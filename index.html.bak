                    </div>
                </div>

                <div class="flex-1">

                    <!-- Promotional Banners Carousel -->
                    <div
                        class="relative w-full rounded-3xl shadow-sm border border-emerald-200 overflow-hidden bg-[#F4F9F2] mb-6 group">

                        <div id="promo-carousel" class="flex w-full">
