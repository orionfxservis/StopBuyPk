                    <i class="fas fa-circle-info text-xs"></i> About Us
                </a>
            </li>

            <li>
                <a href="pages/contact.html"
                   class="flex items-center gap-2 px-4 py-2 hover:bg-emerald-50 hover:text-emerald-700">
                    <i class="fas fa-envelope text-xs"></i> Contact Us
                </a>
            </li>

        </ul>

    </div>
</div>

            <div class="flex items-center gap-x-1 overflow-x-auto whitespace-nowrap w-full no-scrollbar">
                <div class="flex items-center gap-x-0.5 text-white flex-1 text-xs xl:text-[13px] justify-between">
                    <div onclick="showPage('groceries')"
                        class="px-1 py-0.5 bg-emerald-700 text-white rounded-2xl flex items-center cursor-pointer">
                        <span class="px-2 text-xs xl:text-[13px] font-semibold">All Categories</span>
                    </div>
                    <div onclick="showPage('groceries')" class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Daily Groceries</div>
                    <div onclick="showPage('foodstuffs')"
                        class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Food Stuffs</div>
                    <div onclick="showPage('electronics')"
                        class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Electronics</div>
                    <div onclick="showPage('mobiles')" class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Mobiles</div>
                    <div onclick="showPage('laptops')" class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Laptops</div>
                    <div onclick="showPage('fashion')" class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Fashion
                    </div>
                    <div onclick="showPage('cosmetics')" class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Cosmetics
                    </div>
                    <div onclick="showPage('babycare')" class="px-2 py-1 hover:bg-white/10 rounded-2xl cursor-pointer">
                        Baby Care
                    </div>
                </div>

                <!-- Visitor Counter -->
                <div class="hidden md:flex items-center ml-2 xl:ml-4">
                    <div class="animated-border-box">
                        <div class="animated-border-content px-3 py-1 flex items-center gap-x-2 text-white">
                            <span class="text-xs xl:text-[13px] text-emerald-100">Total Visitors</span>
                            <span id="visitor-count"
                                class="font-bold text-emerald-400 tracking-wider text-[13px] xl:text-sm">5,076</span>
                            <i class="fas fa-eye text-emerald-400 text-xs xl:text-[13px]"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

				<!-- HOME PAGE -->
				<div id="home" class="page active">

				<!-- Trends Box (Centered above banner) -->
				<div class="w-full text-center pt-6 pb-2">
					<div class="px-8 py-3 rounded-3xl bg-emerald-700 text-white font-semibold shadow-lg border-2 border-emerald-400 inline-block cursor-default">
					Trends
					</div>
				</div>

		<!-- Hero Banner -->
		<div class="max-w-screen-2xl mx-auto px-4 pb-2 flex items-center justify-between">
			<div class="flex gap-4 items-start">

                <div class="hidden lg:block w-[120px] flex-shrink-0">
                    <div class="sticky top-24 max-h-[720px] overflow-hidden deal-banner">

                        <!-- Vertical Banner Left -->
                        <div class="flex flex-col gap-4">

                            <img src="images/banner/mobiles.jpg"
