                </div>
            </div>
        </div>


        <!-- AI Smart Recommendations -->
        <div class="max-w-screen-2xl mx-auto px-4 pt-6">
            <div
                class="bg-gradient-to-r from-emerald-50 to-emerald-100 border border-emerald-200 rounded-3xl p-5 shadow-sm">

                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 bg-emerald-600 text-white flex items-center justify-center rounded-xl">
                            <i class="fas fa-brain text-sm"></i>
                        </div>
                        <span class="font-semibold text-lg text-emerald-800">Smart Recommendations</span>
                    </div>

                    <div class="text-xs text-emerald-600 font-medium">
                        Based on trends in Karachi
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

                    <!-- BEST DEAL -->
                    <div class="bg-white rounded-2xl p-4 border border-emerald-100 hover:shadow-md transition">
                        <div class="text-xs text-gray-500 mb-1">🔥 Best Deal Today</div>
