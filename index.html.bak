                    </div>

                    <!-- TRENDING -->
                    <div class="bg-white rounded-2xl p-4 border border-emerald-100 hover:shadow-md transition">
                        <div class="text-xs text-gray-500 mb-1">📈 Trending Now</div>
                        <div class="font-semibold">Air Fryer (Kenwood)</div>
                        <div class="text-emerald-700 font-bold text-lg">Rs. 18,500</div>
