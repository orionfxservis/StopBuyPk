                            <li><a href="pages/contact.html" class="hover:text-white">Contact</a></li>
                            <li><a href="#" class="hover:text-white">Careers</a></li>
                            <li><a href="#" class="hover:text-white">Press</a></li>
                            <li><a href="#" class="hover:text-white">Privacy Policy</a></li>
                        </ul>
                    </div>

                    <!-- Col 4 (UPDATED with Newsletter) -->
                    <div>
                        <h3 class="text-[#eab308] font-semibold mb-5">Stay Updated</h3>

                        <!-- Newsletter -->
                        <div class="mb-6">
                            <p class="text-sm text-gray-400 mb-3">Get latest deals & price alerts</p>

                            <div class="flex bg-[#2b3544] rounded-lg overflow-hidden">
                                <input type="email" placeholder="Enter email"
                                    class="flex-1 px-3 py-2 text-sm bg-transparent text-white outline-none">
                                <button onclick="subscribeUser()"
                                    class="bg-emerald-600 hover:bg-emerald-700 px-3 text-sm font-semibold">
                                    Subscribe
                                </button>
                            </div>
                        </div>

                        <!-- Contact -->
                        <ul class="space-y-3 text-sm text-gray-400">
                            <li class="flex items-start gap-2">
                                <i class="fas fa-map-marker-alt text-emerald-500 mt-1"></i>
                                <span>Block 7, Clifton, Karachi</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-phone-alt text-emerald-500"></i>
                                <span>+92 21 111 786 786</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-envelope text-emerald-500"></i>
                                <span>support@stopbuy.pk</span>
                            </li>
                        </ul>
                    </div>

                </div>

                <!-- Bottom -->
                <div
                    class="pt-6 border-t border-[#2b3544] flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-500">
                    <div>© 2026 StopBuy. All rights reserved - Pakistan’s most trusted price comparison
                        platform.</div>
                    <div class="flex gap-5">
                        <a href="#" class="hover:text-white">Terms</a>
                        <a href="#" class="hover:text-white">Privacy</a>
                        <a href="#" class="hover:text-white">Cookies</a>
                    </div>
                </div>

            </div>
        </footer>

        <!-- Floating Action Buttons -->
        <div class="fixed bottom-6 right-6 z-[99999] flex flex-row items-center gap-3">
            <!-- Go to Top Button -->
            <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" id="goTopBtn"
                class="w-12 h-12 bg-emerald-600 hover:bg-emerald-700 text-white rounded-full shadow-lg flex items-center justify-center transition-all duration-300 opacity-0 invisible transform translate-y-4">
                <i class="fas fa-chevron-up text-lg"></i>
            </button>

            <!-- WhatsApp Button -->
            <a href="https://wa.me/" target="_blank"
                class="w-14 h-14 bg-[#25D366] hover:bg-[#1ebe57] text-white rounded-full shadow-lg flex items-center justify-center transition-transform duration-300 hover:scale-110">
                <i class="fab fa-whatsapp text-3xl"></i>
            </a>
        </div>

        <script>
            function animateVisitorCounter() {
                const el = document.getElementById('visitor-count');
                if (!el) return;
                let num = 5076;
                setInterval(() => {
                    num += Math.floor(Math.random() * 3) + 1;
                    el.innerHTML = num.toLocaleString();
                }, 4500);
            }

            function toggleMoreDropdown() {
                const menu = document.getElementById('more-dropdown-menu');
                menu.classList.toggle('hidden');
            }

            function hideMoreDropdown() {
                document.getElementById('more-dropdown-menu').classList.add('hidden');
            }

            function showPage(page) {
                document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
                document.getElementById(page).style.display = 'block';
                window.scrollTo(0, 0);
            }

            function addToCompare(product) {
                alert(product.name + " added to compare!");
            }

            function showTravelModal(id) {
                alert("Travel Package " + id + " details modal would open here.");
            }

            function showBlogModal(id) {
                alert("Blog " + id + " would open in modal.");
            }

            function showSimplePage(type) {
                alert(type + " page would open.");
            }

            function performGlobalSearch() {
                showPage('groceries');
            }

            function showLocationModal() {
                alert("Location selector would open here.");
            }

            function showLoginModal() {
                alert("Login modal would open here.");
            }

            function showAlertsModal() {
                alert("Price alerts modal would open here.");
            }

            function showCompareModal() {
                alert("Compare modal would open here.");
            }

            function initializeWebsite() {
                animateVisitorCounter();
                document.getElementById('home').style.display = 'block';
            }

            window.onload = initializeWebsite;


            function startSyncedInfiniteScroll() {
                const banners = document.querySelectorAll('.deal-banner');

                let scrollSpeed = 0.4; // 👈 ONE GLOBAL SPEED (adjust here)

                banners.forEach(container => {
                    const content = container.firstElementChild;

                    // duplicate content for smooth loop
                    content.innerHTML += content.innerHTML;

                    let scrollTop = 0;

                    function animate() {
                        scrollTop += scrollSpeed;
                        container.scrollTop = scrollTop;

                        if (scrollTop >= content.scrollHeight / 2) {
                            scrollTop = 0;
                            container.scrollTop = 0;
                        }

                        requestAnimationFrame(animate);
                    }

                    animate();
                });
            }

            /* =========================
   🔥 GLOBAL STATE
========================= */
            let currentCategory = 'all';
            let currentSort = 'low';
            let allCards = [];

            /* =========================
               🚀 INIT WEBSITE
            ========================= */
            window.addEventListener('DOMContentLoaded', () => {

                // Store all product cards once
                allCards = Array.from(document.querySelectorAll('.product-card'));

                updateUI();

                initCarousel();
                startAutoSlide();

                startSyncedInfiniteScroll();

            });

            /* =========================
               🧠 MAIN UI ENGINE
            ========================= */
            function updateUI() {

                let filtered = allCards.filter(card => {
                    return currentCategory === 'all' || card.dataset.category === currentCategory;
                });

                // SORTING
                if (currentSort === 'low') {
                    filtered.sort((a, b) => a.dataset.price - b.dataset.price);
                } else if (currentSort === 'high') {
                    filtered.sort((a, b) => b.dataset.price - a.dataset.price);
                } else {
                    filtered.sort((a, b) => a.dataset.distance - b.dataset.distance);
                }

                const grid = document.getElementById('product-grid');
                grid.innerHTML = '';

                if (filtered.length === 0) {
                    grid.innerHTML = `
            <div class="col-span-full text-center text-gray-400 py-10">
                No products found
            </div>`;
                    return;
                }

                filtered.forEach(card => grid.appendChild(card));
            }

            /* =========================
               🎯 CATEGORY BUTTON CLICK
            ========================= */
            function filterCategory(category, btn) {
                currentCategory = category;

                // reset search
                document.getElementById('productSearch').value = "";

                // reset buttons
                document.querySelectorAll('.filter-btn').forEach(b => {
                    b.classList.remove('bg-emerald-700', 'text-white');
                });

                btn.classList.add('bg-emerald-700', 'text-white');

                updateUI();
            }

            /* =========================
               📂 DROPDOWN CATEGORY
            ========================= */
            function filterFromDropdown(value) {

                currentCategory = value || 'all';

                // Remove button highlight
                document.querySelectorAll('.filter-btn').forEach(b => {
                    b.classList.remove('bg-emerald-700', 'text-white');
                });

                updateUI();
            }

            /* =========================
               📊 SORT PRODUCTS
            ========================= */
            function sortProducts(value) {
                currentSort = value;
                updateUI();
            }

            /* =========================
               🎞️ HERO CAROUSEL (FIXED)
            ========================= */
            let currentSlide = 1;
            let slideInterval;
            let totalSlides = 3;
            let isTransitioning = false;

            function initCarousel() {
                const carousel = document.getElementById('promo-carousel');
                if (!carousel) return;

                const slides = Array.from(carousel.children);
                totalSlides = slides.length;

                // Clone first and last slides for seamless looping
                const firstClone = slides[0].cloneNode(true);
                const lastClone = slides[totalSlides - 1].cloneNode(true);

                carousel.appendChild(firstClone);
                carousel.insertBefore(lastClone, slides[0]);

                // Start at the first actual slide (index 1)
                carousel.style.transition = 'none';
                carousel.style.transform = `translateX(-100%)`;

                // Handle smooth snapping after transition
                carousel.addEventListener('transitionend', () => {
                    isTransitioning = false;
                    if (currentSlide === totalSlides + 1) {
                        carousel.style.transition = 'none';
                        currentSlide = 1;
                        carousel.style.transform = `translateX(-100%)`;
                    }
                    if (currentSlide === 0) {
                        carousel.style.transition = 'none';
                        currentSlide = totalSlides;
                        carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
                    }
                });
            }

            function updateCarousel() {
                const carousel = document.getElementById('promo-carousel');
                if (!carousel) return;

                carousel.style.transition = 'transform 0.5s ease-in-out';
                carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
                updateDots();
            }

            function updateDots() {
                const dots = document.querySelectorAll('.promo-dot');
                dots.forEach(dot => {
                    dot.classList.remove('bg-emerald-700');
                    dot.classList.add('bg-black/20');
                });

                let dotIndex = currentSlide - 1;
                if (dotIndex === totalSlides) dotIndex = 0;
                if (dotIndex === -1) dotIndex = totalSlides - 1;

                if (dots[dotIndex]) {
                    dots[dotIndex].classList.remove('bg-black/20', 'hover:bg-black/40');
                    dots[dotIndex].classList.add('bg-emerald-700');
                }
            }

            function nextSlide() {
                if (isTransitioning) return;
                isTransitioning = true;
                currentSlide++;
                updateCarousel();
                startAutoSlide();
            }

            function prevSlide() {
                if (isTransitioning) return;
                isTransitioning = true;
                currentSlide--;
                updateCarousel();
                startAutoSlide();
            }

            function goToSlide(index) {
                if (isTransitioning) return;
                currentSlide = index + 1;
                updateCarousel();
                startAutoSlide();
            }

            function startAutoSlide() {
                clearInterval(slideInterval);
                slideInterval = setInterval(nextSlide, 4000);
            }

            /* =========================
               🔥 VERTICAL BANNER SCROLL (FIXED)
            ========================= */
            function startVerticalScroll() {
                const container = document.getElementById('vertical-scroll');
                if (!container) return;

                let scrollAmount = 0;

                setInterval(() => {
                    scrollAmount += 1;
                    container.scrollTop = scrollAmount;

                    // Reset scroll (loop)
                    if (scrollAmount >= container.scrollHeight / 2) {
                        scrollAmount = 0;
                    }

                }, 30);
            }

            /* =========================
               📍 LOCATION (OPTIONAL)
            ========================= */
            function requestUserLocation() {
                if (navigator.geolocation) {
                    navigator.geolocation.getCurrentPosition(
                        (pos) => console.log("Location:", pos.coords),
                        () => console.log("Location denied")
                    );
                }
            }

            /* =========================
               📩 NEWSLETTER
            ========================= */
            function subscribeUser() {
                alert("Subscribed successfully!");
            }

            function searchProducts(query) {
                query = query.toLowerCase();

                const cards = document.querySelectorAll('.product-card');

                cards.forEach(card => {
                    const name = card.innerText.toLowerCase();

                    if (name.includes(query)) {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            /* =========================
               🚀 FLOATING BUTTONS LOGIC
            ========================= */
            window.addEventListener('scroll', () => {
                const goTopBtn = document.getElementById('goTopBtn');
                if (window.scrollY > 300) {
                    goTopBtn.classList.remove('opacity-0', 'invisible', 'translate-y-4');
                    goTopBtn.classList.add('opacity-100', 'visible', 'translate-y-0');
                } else {
                    goTopBtn.classList.add('opacity-0', 'invisible', 'translate-y-4');
                    goTopBtn.classList.remove('opacity-100', 'visible', 'translate-y-0');
                }
            });
        </script>
</body>

</html>