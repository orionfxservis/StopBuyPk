                        </div>

                        <!-- Carousel Dots -->
                        <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2 z-20">
                            <button onclick="goToSlide(0)"
                                class="w-2.5 h-2.5 rounded-full bg-emerald-700 transition-colors promo-dot"></button>
                            <button onclick="goToSlide(1)"
                                class="w-2.5 h-2.5 rounded-full bg-black/20 hover:bg-black/40 transition-colors promo-dot"></button>
                            <button onclick="goToSlide(2)"
                                class="w-2.5 h-2.5 rounded-full bg-black/20 hover:bg-black/40 transition-colors promo-dot"></button>
                        </div>

                        <!-- Carousel Navigation -->
                        <button onclick="prevSlide()"
                            class="absolute left-4 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/80 flex items-center justify-center text-emerald-800 shadow opacity-0 group-hover:opacity-100 transition-opacity z-20">
                            <i class="fas fa-chevron-left text-sm"></i>
                        </button>
                        <button onclick="nextSlide()"
                            class="absolute right-4 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/80 flex items-center justify-center text-emerald-800 shadow opacity-0 group-hover:opacity-100 transition-opacity z-20">
                            <i class="fas fa-chevron-right text-sm"></i>
                        </button>

                        <!-- Deal Ends Counter Overlay -->
                        <div
                            class="hidden sm:block absolute right-16 top-1/2 transform -translate-y-1/2 bg-white p-4 rounded-2xl shadow-[0_4px_20px_rgb(0,0,0,0.08)] z-20 w-[170px] text-center">
                            <div class="text-[11px] text-emerald-900 font-semibold mb-1 text-left">Deal ends in</div>
