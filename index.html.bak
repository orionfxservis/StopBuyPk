                    </div>

                </div>
            </div>
        </div>
        <!-- Top Price Comparison -->
        <div class="max-w-screen-2xl mx-auto px-4 pt-9">

            <!-- Header -->
            <div class="mb-5">
                <div class="text-xs text-red-500 tracking-widest font-bold mb-1">
                    POWERED BY REAL-TIME DATA
                </div>
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                    <div>
                        <div class="text-3xl font-bold text-[#0A3D2A]">Price Comparison</div>
                        <div class="text-gray-500 text-sm">Find the lowest prices near you</div>
