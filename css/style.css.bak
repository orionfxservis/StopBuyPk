/* =========================
   Orion FX - FINAL CLEAN CSS
   ========================= */

:root {
    --primary-color: #cca43b;
    --secondary-color: #8b5a2b;
    --dark-bg: #1a1a1a;
    --light-text: #ffffff;
    --font-main: 'Outfit', sans-serif;
}

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: var(--font-main);
    background: var(--dark-bg);
    color: var(--light-text);
    overflow-x: hidden;
}

/* ================= NAVBAR ================= */
.navbar {
    position: fixed;
    width: 100%;
    top: 0;
    padding: 15px 40px;
    display: flex;
    justify-content: space-between;
    z-index: 1000;
    background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent);
}

.logo {
    font-size: 2rem;
    font-weight: bold;
    color: var(--primary-color);
}

/* ================= HERO ================= */
.hero {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
}

.hero-slider {
    position: absolute;
    width: 100%;
    height: 100%;
    z-index: -1;
}

.slide {
    position: absolute;
    width: 100%;
    height: 100%;
    background-size: cover;
    opacity: 0;
    transition: 1.2s;
}

.slide.active {
    opacity: 1;
}

.hero-content {
    text-align: center;
    max-width: 900px;
}

/* Typed */
.typed-text {
    font-size: 2.6rem;
    font-weight: 700;
    margin-bottom: 5px;
}

.typed-subtext {
    font-size: 1rem;
    margin-bottom: 15px;
}

/* BUTTON */
.deal-hero-btn {
    padding: 8px 20px;
    font-size: 0.85rem;
    border-radius: 20px;
    background: linear-gradient(45deg,#ff416c,#ff4b2b);
    color: #fff;
    display: inline-block;
    margin-bottom: 20px;
}

/* ================= SEARCH PANEL ================= */
.search-panel {
    max-width: 900px;
    margin: auto;
    background: #1c1c1c;
    padding: 15px;
    border-radius: 12px;
}

/* CATEGORY SECTION */
.category-wrapper {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 10px;
}

/* ROWS */
.category-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 6px;
}

/* FIRST ROW (ALL) */
.category-row.single {
    grid-template-columns: 1fr;
}

.category-row.single .cat-box {
    max-width: 150px;
    margin: auto;
}

/* CATEGORY BOX */
.cat-box {
    background: rgba(255,255,255,0.05);
    padding: 6px;
    border-radius: 8px;
    font-size: 11px;
    text-align: center;
    cursor: pointer;
    transition: 0.25s;
}

.cat-box i {
    display: block;
    font-size: 14px;
    margin-bottom: 3px;
}

.cat-box:hover {
    background: rgba(255,255,255,0.1);
    transform: translateY(-2px);
}

.cat-box.active {
    background: linear-gradient(45deg,var(--primary-color),var(--secondary-color));
    color: #000;
}

/* ================= SEARCH ROW ================= */
.search-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr auto auto auto;
    gap: 6px;
    align-items: center;
}

/* INPUTS */
.search-row input,
.search-row select {
    height: 34px;
    padding: 0 10px;
    border-radius: 6px;
    font-size: 0.8rem;
    border: none;
}

/* BUTTONS */
.search-row button {
    height: 34px;
    padding: 0 10px;
    font-size: 0.75rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
}

/* BUTTON COLORS */
.voice-btn {
    background: var(--primary-color);
}

.location-btn {
    background: #333;
    color: #fff;
}

.search-btn {
    background: linear-gradient(45deg,var(--primary-color),var(--secondary-color));
    color: #000;
    font-weight: bold;
}

/* ================= CATEGORY SLIDER ================= */
.category-slider {
    margin-top: 10px;
    overflow-x: auto;
}

.slider-track {
    display: flex;
    gap: 8px;
}

.slide-item {
    min-width: 100px;
    padding: 6px;
    border-radius: 15px;
    background: rgba(255,255,255,0.05);
    font-size: 12px;
    text-align: center;
    cursor: pointer;
}

.slide-item:hover {
    background: var(--primary-color);
    color: #000;
}

/* ================= POPULAR SEARCH ================= */
.popular-searches {
    margin-top: 10px;
    text-align: center;
}

.popular-searches button {
    padding: 5px 10px;
    font-size: 0.7rem;
    border-radius: 12px;
    margin: 3px;
    border: none;
    cursor: pointer;
    background: rgba(255,255,255,0.1);
}

.popular-searches button:hover {
    background: var(--primary-color);
    color: #000;
}

/* ================= MOBILE ================= */
@media(max-width:768px){

    .category-row {
        grid-template-columns: repeat(3,1fr);
    }

    .search-row {
        grid-template-columns: 1fr;
    }

    .search-row button {
        width: 100%;
    }
}

/* ===== POPULAR (TOP) ===== */
.popular-searchs-top {
    margin: 10px 0 15px;
    text-align: center;
}

.popular-searchs-top button {
    background: rgba(255,255,255,0.1);
    border: none;
    padding: 6px 12px;
    margin: 4px;
    border-radius: 20px;
    color: #fff;
    cursor: pointer;
}

.popular-searchs-top button:hover {
    background: var(--primary-color);
    color: #000;
}


/* ===== CATEGORY BAR ===== */
.category-bar {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 12px 20px;
    margin-top: 10px;
}

.category-bar::-webkit-scrollbar {
    display: none;
}

.bar-item {
    background: rgba(255,255,255,0.06);
    padding: 8px 14px;
    border-radius: 20px;
    white-space: nowrap;
    cursor: pointer;
    transition: 0.3s;
}

.bar-item:hover {
    background: var(--primary-color);
    color: #000;
}


/* ===== FIX PRODUCT GRID ===== */
.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    width: 100%;
}

/* FIX CARD WIDTH */
.product-card {
    width: 100%;
    max-width: 100%;
    text-align: left;
}

/* IMAGE FIX */
.product-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

/* TEXT ALIGN */
.product-card h3 {
    font-size: 16px;
}

.price {
    font-size: 15px;
}

.location {
    font-size: 12px;
    opacity: 0.7;
}

/* FIX SECTION WIDTH */
.products-section {
    max-width: 1200px;
    margin: auto;
}